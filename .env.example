# Copy this file to .env and fill in the values for local development.
# Secrets managed by Replit (DATABASE_URL, SESSION_SECRET, JWT_SECRET, etc.)
# are injected automatically — do not add them here.

# Giphy API key — required for GIF search in global chat.
# Get your own key at https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here
