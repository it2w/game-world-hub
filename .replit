modules = ["nodejs-24", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "web-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lfg-e2e"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "web-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/game-world-hub run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lfg-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/game-world-hub && PLAYWRIGHT_BASE_URL=http://localhost:80 PLAYWRIGHT_API_BASE=http://localhost:80/api pnpm exec playwright test --config playwright.config.ts"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
EMAIL_FROM = "Game World Hub <info@gmes.app>"

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-6a89c14e-81ab-4905-a936-b45fe63aeede"
