{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "test": "node --import tsx --test --test-force-exit src/ws/signaling.test.ts src/routes/parties.test.ts src/routes/conversations.test.ts src/routes/lfg.test.ts src/routes/users.test.ts src/middlewares/admin.test.ts src/routes/reports.test.ts src/routes/admin.test.ts src/routes/owner.test.ts src/routes/prestige.test.ts src/routes/events.test.ts src/routes/factions.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@replit/connectors-sdk": "^0.4.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.17.0",
    "otplib": "^13.4.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/busboy": "^1.5.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
