{
  "name": "@workspace/game-world-hub-desktop",
  "version": "1.0.0",
  "description": "Game World Hub — Windows Desktop App",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "build:ts": "tsc --noEmit false",
    "build:web": "pnpm --filter @workspace/game-world-hub run build",
    "build:main": "tsc",
    "build:icon": "node scripts/generate-icon.mjs",
    "build:server": "pnpm --filter @workspace/api-server run build",
    "build": "pnpm run build:main",
    "build:win": "pnpm run build:server && pnpm run build:main && electron-builder --win",
    "build:win:portable": "pnpm run build:server && pnpm run build:main && electron-builder --win portable",
    "build:win:msix": "pnpm run build:server && pnpm run build:main && electron-builder --win appx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "electron-builder-squirrel-windows": "25.1.8",
    "typescript": "~5.9.3"
  },
  "build": {
    "extends": null,
    "appId": "com.gameworldhub.desktop",
    "productName": "Game World Hub",
    "copyright": "Copyright © 2025 Game World Hub",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "appx",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Game World Hub",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "shortcutName": "Game World Hub",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "GameWorldHubSetup.exe"
    },
    "appx": {
      "identityName": "GameWorldHub.GameWorldHub",
      "publisher": "CN=86042C5F-91A6-4FD9-BFF9-FFE37C24DB2C",
      "publisherDisplayName": "Game World Hub",
      "applicationId": "GameWorldHub",
      "displayName": "Game World Hub",
      "backgroundColor": "#0a0a0a",
      "showNameOnTiles": true,
      "languages": ["ar-SA", "en-US"],
      "artifactName": "GameWorldHub-${version}-x64.msix"
    },
    "publish": {
      "provider": "github",
      "owner": "gameworldhub",
      "repo": "desktop-releases",
      "releaseType": "release"
    },
    "protocols": [
      {
        "name": "Game World Hub",
        "schemes": ["gameworldhub"]
      }
    ]
  }
}
